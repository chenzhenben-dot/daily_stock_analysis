# =============================================================
# OrbStack 本地预发布环境变量示例
#
# 用途：
#   - 复制为 .env.orbstack.local（已被 .gitignore），填入真实 Key。
#   - 只放变量名和安全占位值，**不包含任何真实 Secret**。
#   - 缺 Key 时 Compose 仍可启动 UI 与 healthcheck，但完整分析将失败。
#
# 与生产完全独立：本地可放任意占位，生产 .env 永远不会被本 compose 引用。
# =============================================================

# —— 业务可选：自选股列表 ——
# STOCK_LIST=600519,300750,002594

# —— 通知 / 定时 / Moomoo ——
# 本地预发布强制关闭：scheduler 已通过 CLI 参数关闭，--no-notify 在 compose 命令里。
# 即便在此文件里设置下列变量，也不会重启调度或推送。
# DSA_DISABLE_SCHEDULER=1
# DSA_DISABLE_NOTIFY=1

# —— DSA LLM / 数据源（可全部留空，仅用于基础 UI smoke）——
# ANSPIRE_API_KEYS=
# TUSHARE_TOKEN=
# FINNHUB_API_KEY=
# ALPHAVANTAGE_API_KEY=

# —— ER Dashboard 反链 URL ——
# 本地默认指向 dsa-local 容器；不需要改。
# ER_DSA_URL=http://127.0.0.1:18088/

# —— 生产严禁复制到这里 ——
# TELEGRAM_BOT_TOKEN=<production token>   # 不要填、不要粘贴
# CLOUDFLARED_TUNNEL_TOKEN=<production>   # 不要填、不要粘贴
# LONGBRIDGE_ACCESS_TOKEN=<production>    # 不要填、不要粘贴
# MOOMOO_OPEND_PASSWORD=<production>      # 不要填、不要粘贴